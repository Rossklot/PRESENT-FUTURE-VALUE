def accumulate(iterable, func=operator.add, *, initial=None):
    'Return running'
    it = iter(iterable)
    total = initial
    if initial is None:
        try:
            total = next(it)
        except stopIteration:
                return
        yield total
        for element in it:
                total = func(total, element)
                yield total

